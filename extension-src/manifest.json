{
  "manifest_version": 3,
  "name": "SourceCapsule",
  "version": "1.3.0",
  "description": "Save complete X threads, Articles, and posts as offline archives, agent-ready Markdown, or expiring share links.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://mobile.x.com/*",
    "https://mobile.twitter.com/*",
    "https://*.twimg.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://sourcecapsule-share.wolfgang-aura.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["compat.js", "sourcecapsule.user.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "SourceCapsule",
    "default_popup": "popup.html"
  }
}
